{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RouterOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "route_key",
    "confidence",
    "retrieval_scope",
    "search_mode",
    "should_offer_store_url",
    "selected_candidate_product_keys",
    "rationale"
  ],
  "properties": {
    "route_key": {
      "type": "string",
      "enum": [
        "storefront_order",
        "exact_product_quote",
        "brand_catalog",
        "generic_sales",
        "store_info"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "retrieval_scope": {
      "type": "string",
      "enum": [
        "none",
        "store_info",
        "catalog_narrow",
        "catalog_broad",
        "storefront_handoff"
      ]
    },
    "search_mode": {
      "type": "string",
      "enum": [
        "exact",
        "tier_browse",
        "brand_browse",
        "storefront_handoff",
        "info"
      ]
    },
    "should_offer_store_url": {
      "type": "boolean"
    },
    "selected_candidate_product_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "maxItems": 6
    },
    "rationale": {
      "type": "string",
      "maxLength": 240
    }
  }
}
